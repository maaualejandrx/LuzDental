---
const { pathname } = Astro.url;
const currentPath = pathname.replace(/\/$/, "");

const navItems = [
  { href: "/", label: "Inicio" },
  { href: "/about", label: "Nosotros" },
  { href: "/services", label: "Servicios" },
  { href: "/contact", label: "Contáctanos" },
];
---

<div class="w-full fixed top-0 left-0 px-6 pt-6 z-50">
  
  <header class="max-w-6xl mx-auto flex items-center justify-between bg-black/10 backdrop-blur-md border border-white/20 px-8 py-3 rounded-2xl shadow-sm">
    
    <a href="/" class="flex items-center gap-2">
      <img 
        src="/logo.png" 
        alt="Luz Dental Logo" 
        class="h-10 w-auto object-contain"
      />
    </a>
    <nav class="flex items-center space-x-8">
      {navItems.map((item) => {
        const isActive = currentPath === item.href || (item.href !== "/" && currentPath.startsWith(item.href));
        return (
          <a 
            href={item.href} 
            class={`text-sm font-semibold transition-colors ${
              isActive 
                ? "text-blue-600" 
                : "text-slate-800 hover:text-blue-600"
            }`}
          >
            {item.label}
          </a>
        );
      })}
    </nav>

    <div>
      <a 
        href="/book" 
        class="inline-block text-sm font-bold bg-blue-600 text-white px-6 py-2.5 rounded-xl hover:bg-blue-700 transition-colors shadow-sm"
      >
        Agenda tu cita
      </a>
    </div>

  </header>
</div>