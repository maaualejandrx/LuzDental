---
import { Image } from 'astro:assets';
import doctoraImg from '../images/doctora.png'; 
---

<section class="w-full min-h-screen flex items-center bg-gradient-to-r from-[#00B2FF]/50 via-[#00B2FF]/15 to-[#FAFAFA] to-100% pt-24 pb-12 overflow-hidden">
  <div class="w-full max-w-[1440px] mx-auto px-4 sm:px-8 grid grid-cols-1 lg:grid-cols-12 gap-4 items-center">    
    <div class="lg:col-span-5 flex justify-center items-center relative order-2 lg:order-1 mt-12 lg:mt-0">
      <div class="relative w-[387px] h-[685px] sm:w-[387px] sm:h-[685px] rounded-[20px] overflow-hidden shadow-2xl bg-slate-100 ">
        <Image 
          src={doctoraImg} 
          alt="CD. Luz Elena Álvarez López" 
          class="w-full h-full object-cover object-center scale-105"
          loading="lazy"
        />
      </div>
    </div>
    <div class="lg:col-span-7 flex flex-col items-center lg:items-end text-center lg:text-right space-y-6 order-1 lg:order-2 lg:pl-12">      
      <h1 class="text-5xl sm:text-7xl xl:text-8xl font-black text-[#0c1230] tracking-tighter leading-[0.95] w-full">
        Ayudando a los<br />
        dientes de todo<br />
        <span class="text-[#0076c8]">Tabasco</span>
      </h1>      
      <p class="text-2xl sm:text-3xl font-extrabold text-[#1d2939]">
        CD. Luz Elena Álvarez López
      </p>
    </div>
  </div>
</section>
