---
import { Image } from 'astro:assets';
import doctoraImg from '../images/doctora.png'; 
---

<section class="w-full h-screen sticky top-0 bg-gradient-to-r from-[#00B2FF]/50 via-[#00B2FF]/15 to-[#FAFAFA] to-100% pt-24 pb-12 overflow-hidden relative z-0">  <div class="w-full max-w-[1440px] mx-auto px-4 sm:px-8 grid grid-cols-1 lg:grid-cols-12 gap-4 items-center">    
    <div class="lg:col-span-7 flex flex-col items-center lg:items-start text-center lg:text-left space-y-6 order-1 lg:pr-12">      
      <h1 class="text-5xl sm:text-7xl xl:text-8xl font-black text-[#0c1230] tracking-tighter leading-[0.95] w-full flex flex-col items-center lg:items-start">
        
        <!-- Línea 1 -->
        <span class="inline-block animate-typing overflow-hidden whitespace-nowrap pr-1 max-w-max">
          Ayudando a los
        </span>
        
        <!-- Línea 2 -->
        <span class="inline-block opacity-0 animate-typing [animation-delay:1.2s] overflow-hidden whitespace-nowrap pr-1 max-w-max">
          dientes de todo
        </span>
        
        <!-- Línea 3 -->
        <span class="inline-block text-[#0076c8] opacity-0 animate-typing [animation-delay:2.4s] overflow-hidden whitespace-nowrap border-r-4 border-r-[#0076c8] pr-2 max-w-max">
          Tabasco
        </span>

      </h1>      
      <p class="text-2xl sm:text-3xl font-extrabold text-[#1d2939] opacity-0 animate-jump-in [animation-delay:3.6s]">
        CD. Luz Elena Álvarez López
      </p>
    </div>

        <!-- BLOQUE DE IMAGEN INTERACTIVO CON DIENTES GIGANTES Y LIBRES -->
    <div class="lg:col-span-5 flex justify-center items-center relative order-2 mt-12 lg:mt-0 overflow-visible">
      
      <!-- Contenedor maestro de la foto que flota de forma lenta en bloque -->
      <div class="relative w-[387px] h-[685px] sm:w-[387px] sm:h-[685px] rounded-[20px] overflow-visible shadow-2xl bg-slate-100 animate-float-card-slow">
        
        <!-- ========================================================================= -->
        <!-- DIENTE 1: SUPERIOR DERECHO (Gorro - Ampliado a w-20 h-20) -->
        <!-- ========================================================================= -->
        <div class="absolute -top-6 -right-12 animate-float-card z-20">
          <img src="/diente.svg" alt="Diente Clínico" class="w-20 h-20 object-contain transform rotate-12 filter drop-shadow-lg" />
        </div>

        <!-- ========================================================================= -->
        <!-- DIENTE 2: MEDIO DERECHO (Ojos / Oreja - Ampliado a w-20 h-20) -->
        <!-- ========================================================================= -->
        
        <div class="absolute top-[40%] -right-14 animate-float-card z-20">
          <img src="/diente.svg" alt="Diente Clínico" class="w-20 h-20 object-contain filter drop-shadow-lg" />
        </div>

        <!-- ========================================================================= -->
        <!-- DIENTE 3: INFERIOR IZQUIERDA (Base - Ampliado a w-20 h-20) -->
        <!-- ========================================================================= -->
        <div class="absolute -bottom-10 -left-12 animate-float-card z-20">
          <img src="/diente.svg" alt="Diente Clínico" class="w-20 h-20 object-contain transform -rotate-12 filter drop-shadow-lg" />
        </div>

        <!-- RECUADRO DE LA FOTO REAL CON EFECTO BLUR-FADE -->
        <div class="absolute inset-0 rounded-[20px] overflow-hidden bg-slate-100 animate-blur-fade z-10">
          <Image 
            src={doctoraImg} 
            alt="CD. Luz Elena Álvarez López" 
            class="w-full h-full object-cover object-center scale-105"
            loading="lazy"
          />
        </div>

      </div>
    </div>


  </div>
</section>


  </div>
</section>
