---
import { Image } from 'astro:assets';
import nosotrosComposicionImg from '../images/nosotros-composicion.png';  
---

<section class="w-full min-h-screen flex items-center bg-[#FAFAFA] py-20 overflow-hidden">
  <div class="w-full max-w-[1440px] mx-auto px-4 sm:px-8 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-7 flex flex-col items-start text-left space-y-8 pr-0 lg:pr-12">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 w-full">
        <div class="flex flex-col items-start space-y-2">
          <div class="p-3 bg-blue-50 rounded-xl text-[#0076c8]">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-black text-[#0c1230]">Precio accesible</h3>
          <p class="text-sm text-slate-500 max-w-xs leading-relaxed">Con precios accesibles para todo el público</p>
        </div>
        <div class="flex flex-col items-start space-y-2">
          <div class="p-3 bg-blue-50 rounded-xl text-[#0076c8]">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="text-lg font-black text-[#0c1230]">Servicio de calidad</h3>
          <p class="text-sm text-slate-500 max-w-xs leading-relaxed text-justify">Servicio satisfactorio y de alta calidad, con herramientas e instrumental adecuado para cada operación</p>
        </div>
      </div>
      <h2 class="text-4xl sm:text-5xl xl:text-6xl font-black text-[#0c1230] tracking-tighter leading-[1.05] w-full max-w-2xl">
        La cirujana dentista más <span class="text-[#0076c8]">confiable</span> que puedes encontrar
      </h2>
      <p class="text-lg text-slate-600 font-medium max-w-2xl leading-relaxed tracking-wide text-justify">
        cirujana dentista con experiencia en .... estudiante de la ujat blabla especializada enTempus turpis laoreet commodo suspendisse commodo mus vitae molestie aliquet sodales lectus massa.
      </p>
    </div>
    <div class="lg:col-span-5 flex justify-center items-center relative">
      <div class="w-full max-w-[480px] lg:max-w-none">
        <Image
          src={nosotrosComposicionImg} 
          alt="Composición de la Doctora y detalles visuales" 
          class="w-full h-auto object-contain block"
        />
      </div>
    </div>
  </div>
</section>
