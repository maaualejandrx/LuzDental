---
import { Image } from 'astro:assets';
import logoImg from '../images/ruta-de-tu-logo.png'; 

// Año dinámico automático
const currentYear = new Date().getFullYear();
---

<footer class="w-full bg-[#0F172B] text-slate-300 pb-8 overflow-hidden relative z-30 block">
  
  <div class="w-full h-2 bg-gradient-to-r from-[#176AD8] via-[#176AD8]/60 to-transparent"></div>

  <div class="max-w-[1440px] mx-auto px-4 sm:px-8 space-y-12 pt-12"> 
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start w-full">
      <div class="flex flex-col space-y-6 items-start">
        <a href="/" class="flex items-center h-12">
          <img src="/logo.png" alt="Luz Dental" class="h-full w-auto" />
        </a>

        <div class="flex flex-wrap gap-3">
          <a href="#" class="w-12 h-12 rounded-xl bg-slate-900/40 border border-slate-800 flex items-center justify-center text-slate-400 hover:bg-[#0076c8] hover:text-white transition-all duration-200">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>
          </a>
          <a href="#" class="w-12 h-12 rounded-xl bg-slate-900/40 border border-slate-800 flex items-center justify-center text-slate-400 hover:bg-[#0076c8] hover:text-white transition-all duration-200">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37zM17.5 6.5h.01"/></svg>
          </a>
          <a href="#" class="w-12 h-12 rounded-xl bg-slate-900/40 border border-slate-800 flex items-center justify-center text-slate-400 hover:bg-[#0076c8] hover:text-white transition-all duration-200">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12.525.02c1.31.01 2.61.03 3.91.05.01 1.03.44 2.01 1.19 2.72.78.72 1.8 1.12 2.85 1.13v3.83c-1.12-.01-2.22-.32-3.18-.92-.61-.39-1.13-.93-1.52-1.57v7.26c0 1.2-.33 2.37-.96 3.39-.67 1.05-1.67 1.83-2.84 2.21-1.26.41-2.62.38-3.86-.11-1.21-.49-2.22-1.39-2.86-2.55C4.2 14.18 4 12.8 4.43 11.5c.39-1.16 1.19-2.14 2.24-2.76 1.1-.64 2.38-.89 3.65-.71V11.9c-.83-.16-1.7.02-2.39.51-.62.43-1.01 1.12-1.07 1.88-.08.97.52 1.89 1.45 2.19.64.21 1.34.14 1.93-.21.57-.34.92-.95.93-1.62V.02h1.36z"/></svg>
          </a>
          <a href="#" class="w-12 h-12 rounded-xl bg-slate-900/40 border border-slate-800 flex items-center justify-center text-slate-400 hover:bg-[#0076c8] hover:text-white transition-all duration-200">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.163a3.003 3.003 0 00-2.11-2.11C19.517 3.545 12 3.545 12 3.545s-7.517 0-9.388.508a3.003 3.003 0 00-2.11 2.11c-.51 1.871-.51 5.776-.51 5.776s0 3.905.51 5.776a3.003 3.003 0 002.11 2.11c1.871.508 9.388.508 9.388.508s7.517 0 9.388-.508a3.003 3.003 0 002.11-2.11c.51-1.871.51-5.776-.51-5.776s0-3.905-.51-5.776zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
          <a href="#" class="w-12 h-12 rounded-xl bg-white text-[#0c1230] flex items-center justify-center font-black text-xl hover:bg-slate-100 transition-all duration-200 shadow-sm" aria-label="Lightning Solutions">
            ⚡
          </a>
        </div>
      </div>

      <div class="flex flex-col space-y-5 md:items-end lg:items-start md:pl-12 lg:pl-32">
        
        <div class="flex items-center gap-4 text-sm font-semibold tracking-wide text-slate-200">
          <div class="w-8 h-8 shrink-0 flex items-center justify-center text-emerald-400">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <p class="leading-relaxed">
            C. 5 6315, Gaviotas Nte. Sector Popular,<br />86068 Villahermosa, Tab.
          </p>
        </div>

        <div class="flex items-center gap-4 text-sm font-semibold tracking-wide text-slate-200">
          <div class="w-8 h-8 shrink-0 flex items-center justify-center bg-white rounded-md p-1 shadow-sm">
            <svg class="w-full h-full text-red-500" fill="currentColor" viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
          </div>
          <a href="mailto:luzdental@gmail.com" class="underline hover:text-white transition-colors">
            luzdental@gmail.com
          </a>
        </div>

        <div class="flex items-center gap-4 text-sm font-semibold tracking-wide text-slate-200">
          <div class="w-8 h-8 shrink-0 flex items-center justify-center text-emerald-500">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M20.01 15.38c-1.23 0-2.42-.2-3.53-.56a.977.977 0 00-1.01.24l-2.2 2.2a15.045 15.045 0 01-6.59-6.59l2.2-2.21c.28-.26.36-.65.25-1A11.36 11.36 0 018.5 4c0-.55-.45-1-1-1H4c-.55 0-1 .45-1 1 0 9.39 7.61 17 17 17 .55 0 1-.45 1-1v-3.5c0-.55-.45-1-1-1z"/></svg>
          </div>
          <a href="tel:+529931296214" class="hover:text-white transition-colors">
            +52 99 31 29 62 14
          </a>
        </div>

      </div>
    </div>

    <div class="w-full border-t border-slate-800/80 pt-8">
      <p class="text-xs text-slate-500 font-medium tracking-wide">
        {currentYear} LuzDental - M Intertainet Technology 
      </p>
    </div>

  </div>
</footer>