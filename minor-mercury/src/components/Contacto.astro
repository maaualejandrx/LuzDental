---
// Listado de los horarios extraídos tal cual de tu Figma
const horarios = [
  { dia: "Lunes", horas: "15:00 PM - 19:00 PM", cerrado: false },
  { dia: "Martes", horas: "15:00 PM - 19:00 PM", cerrado: false },
  { dia: "Miércoles", horas: "15:00 PM - 19:00 PM", cerrado: false },
  { dia: "Jueves", horas: "15:00 PM - 19:00 PM", cerrado: false },
  { dia: "Viernes", horas: "15:00 PM - 19:00 PM", cerrado: false },
  { dia: "Sábado", horas: "Cerrado", cerrado: true },
  { dia: "Domingo", horas: "Cerrado", cerrado: true },
];
---

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
<script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

<section class="w-full bg-[#FAFAFA] py-24 overflow-hidden">
  <div class="max-w-[1440px] mx-auto px-4 sm:px-8 space-y-12">
    
    <!-- ENCABEZADO DE LA SECCIÓN (Igual al de tu Figma) -->
    <div class="space-y-3 text-left">
      <h2 class="text-4xl sm:text-5xl xl:text-6xl font-black text-[#0c1230] tracking-tighter leading-none">
        ¿Estas listo para tu cambio?
      </h2>
      <p class="text-lg text-slate-500 font-medium max-w-xl">
        Encuentra el horario que funcione para ti y nosotros nos ajustamos
      </p>
    </div>

    <!-- REJILLA PRINCIPAL (Mitad mapa, Mitad horarios) -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start w-full">
      
      <!-- BLOQUE IZQUIERDO: CONTENEDOR DEL MAPA Y TEXTO DE UBICACIÓN -->
      <div class="flex flex-col space-y-6 w-full h-full justify-between">
        
        <div id="map" 
          class="w-full h-[450px] rounded-[20px] bg-slate-100 border border-slate-200 shadow-sm overflow-hidden relative flex items-center justify-center text-slate-400 font-bold z-10"
        >
          <span>[ Espacio reservado para Leaflet Map API ]</span>
        </div>

        <!-- Texto descriptivo inferior con tipografía marcada -->
        <p class="text-xl font-extrabold text-[#0c1230] leading-relaxed max-w-lg tracking-wide">
          Nos encontramos ubicados en la clínica de Odontología de la UJAT
        </p>
      </div>

      <!-- BLOQUE DERECHO: LISTADO DE HORARIOS TIPO PASTILLA -->
      <div class="flex flex-col space-y-4 w-full">
        {horarios.map((item) => (
          /* Caja contenedora tipo pastilla con el redondeado Figma */
          <div class="w-full flex items-center justify-between bg-[#d2e5f5]/60 border border-[#d2e5f5]/30 px-8 py-4 rounded-[20px] shadow-sm transition-all duration-300 hover:bg-[#d2e5f5]/90 hover:translate-x-2">
            
            <!-- Nombre del Día -->
            <span class="text-lg font-black text-[#0c1230]">
              {item.dia}
            </span>
            
            <!-- Bloque de Horas o Estado Cerrado -->
            <span class={`text-base font-extrabold tracking-wide ${item.cerrado ? 'text-slate-500' : 'text-[#0c1230]'}`}>
              {item.horas}
            </span>

          </div>
        ))}
      </div>

    </div>

  </div>
</section>

<script is:inline>
const direccionACopiar = "C. 5 6315, Gaviotas Nte. Sector Popular, 86068 Villahermosa, Tab."
const googleMapsUrl = `https://www.google.com/maps/place/UJAT+Cl%C3%ADnica+de+Odontolog%C3%ADa+Juchiman+II+UJAT/@17.9873947,-92.9141862,16.67z/data=!4m10!1m2!2m1!1sjuchiman!3m6!1s0x85edd8458a7b234f:0xa52177477d9362f2!8m2!3d17.990742!4d-92.911171!15sCghqdWNoaW1hbloKIghqdWNoaW1hbpIBDm1lZGljYWxfY2xpbmljmgEkQ2hkRFNVaE5NRzluUzBWSlEwRm5TVVExZDBwUVNIQjNSUkFC4AEA-gEECAAQPQ!16s%2Fg%2F11bym__sbg?entry=ttu&g_ep=EgoyMDI2MDUxMy4wIKXMDSoASAFQAw%3D%3D`;



    var map = L.map('map', {
        center: [17.98446, -92.92253],
        zoom: 13
    }).setView([17.990803, -92.911181], 16);

L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
    maxZoom: 19,
    attribution: '&copy; <a href="http://www.openstreetmap.org/copyright">OpenStreetMap</a>'
}).addTo(map);


var marker = L.marker([17.990803, -92.911181]).addTo(map);
marker.bindPopup("<b>UJAT Clínica de Odontología</b><br>Juchiman II UJAT").openPopup();

marker.on('click', function onMarkerClick() {
        navigator.clipboard.writeText(direccionACopiar)
            marker.openPopup();
          })
          .catch(err => {
            console.error('Error al copiar la dirección: ', err);
          });

          
</script>

