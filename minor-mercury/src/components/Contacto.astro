---

import { Image } from 'astro:assets';
import doctoraDImg from '../images/doctora-diente.png';

// Listado de los horarios extraídos tal cual de tu Figma
const horarios = [
  { dia: "Lunes", horas: "15:00 PM - 19:00 PM", cerrado: false },
  { dia: "Martes", horas: "15:00 PM - 19:00 PM", cerrado: false },
  { dia: "Miércoles", horas: "15:00 PM - 19:00 PM", cerrado: false },
  { dia: "Jueves", horas: "15:00 PM - 19:00 PM", cerrado: false },
  { dia: "Viernes", horas: "15:00 PM - 19:00 PM", cerrado: false },
  { dia: "Sábado", horas: "Cerrado", cerrado: true },
  { dia: "Domingo", horas: "Cerrado", cerrado: true },
];
---

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
<section class="w-full bg-[#FAFAFA] py-24 overflow-hidden">
  <div class="max-w-[1440px] mx-auto px-4 sm:px-8 space-y-12">
    
    <!-- ENCABEZADO DE LA SECCIÓN (Igual al de tu Figma) -->
    <div class="space-y-3 text-left">
      <h2 class="text-4xl sm:text-5xl xl:text-6xl font-black text-[#0c1230] tracking-tighter leading-none">
        ¿Estas listo para tu cambio?
      </h2>
      <p class="text-lg text-slate-500 font-medium max-w-xl">
        Encuentra el horario que funcione para ti y nosotros nos ajustamos
      </p>
    </div>

    <!-- REJILLA PRINCIPAL (Mitad mapa, Mitad horarios) -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start w-full">
      
      <!-- BLOQUE IZQUIERDO: CONTENEDOR DEL MAPA Y TEXTO DE UBICACIÓN -->
      <div class="flex flex-col space-y-6 w-full h-full justify-between">
        
        <div id="" 
          class="w-full h-[450px] rounded-[20px] bg-slate-100 border border-slate-200 shadow-sm overflow-hidden relative flex items-center justify-center text-slate-400 font-bold z-10"
        >
        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3794.744405808801!2d-92.91344551667102!3d17.99062463392297!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x85edd8458a7b234f%3A0xa52177477d9362f2!2sUJAT%20Cl%C3%ADnica%20de%20Odontolog%C3%ADa%20Juchiman%20II%20UJAT!5e0!3m2!1ses-419!2smx!4v1779599188014!5m2!1ses-419!2smx" width="800px" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>

        <!-- Texto descriptivo inferior con tipografía marcada -->
        <p class="text-xl font-extrabold text-[#0c1230] leading-relaxed max-w-lg tracking-wide">
          Nos encontramos ubicados en la clínica de Odontología de la UJAT
        </p>
      </div>

      <!-- BLOQUE DERECHO: LISTADO DE HORARIOS TIPO PASTILLA -->
      <div class="flex flex-col space-y-4 w-full">
        {horarios.map((item) => (
          /* Caja contenedora tipo pastilla con el redondeado Figma */
          <div class="w-full flex items-center justify-between bg-[#d2e5f5]/60 border border-[#d2e5f5]/30 px-8 py-4 rounded-[20px] shadow-sm transition-all duration-300 hover:bg-[#d2e5f5]/90 hover:translate-x-2">
            
            <!-- Nombre del Día -->
            <span class="text-lg font-black text-[#0c1230]">
              {item.dia}
            </span>
            
            <!-- Bloque de Horas o Estado Cerrado -->
            <span class={`text-base font-extrabold tracking-wide ${item.cerrado ? 'text-slate-500' : 'text-[#0c1230]'}`}>
              {item.horas}
            </span>

          </div>
        ))}
      </div>

    </div>
  </div>

<!-- CONTENEDOR DE ALINEACIÓN DEL BANNER CORREGIDO -->
<!-- Añadimos 'pt-16' para darle un aire al espacio que invadirá la cabeza de la doctora arriba -->
<div class="w-full pt-16">
  
  <!-- CORRECCIÓN: Cambiamos 'max-w-4xl' por 'max-w-[1440px]' para que se estire al mismo ancho del mapa y horarios -->
  <div class="max-w-[1440px] mx-auto bg-[#e3f2fd] rounded-[20px] p-8 sm:p-10 flex flex-col md:flex-row items-center justify-between gap-6 relative overflow-visible min-h-[320px]">
    
    <!-- BLOQUE IZQUIERDO: TEXTOS MÁS COMPACTOS Y AJUSTADOS -->
    <div class="flex flex-col items-center md:items-start text-center md:text-left space-y-4 z-10 max-w-md">
      <h3 class="text-2xl sm:text-3xl font-black text-[#0c1230] tracking-tight leading-tight">
        ¿Listo para la mejor<br /> experiencia dental?
      </h3>
      
      <p class="text-sm sm:text-base text-slate-600 font-medium leading-relaxed">
        Agenda tu cita hoy, y da el primer paso para una mejor sonrisa
      </p>
      
      <a 
        href="/book" 
        class="inline-block text-xs font-extrabold bg-[#FAFAFA] text-[#0c1230] border border-slate-200 px-6 py-2.5 rounded-full hover:bg-white hover:shadow-sm transition-all duration-200"
      >
        ¡Agenda ahora!
      </a>
    </div>

    <!-- CORRECCIÓN: Ajustamos 'md:right-4' a 'md:right-12' para pegar a la doctora al borde del nuevo ancho masivo -->
    <div class="w-full md:w-auto flex justify-center md:absolute md:bottom-0 md:right-4 z-20">
      
      <!-- Contenedor rígido de la imagen (Mantiene tus medidas exactas) -->
      <div class="w-[350px] h-[max] relative flex items-end justify-center">
        <Image
          src={doctoraDImg}
          alt="Doctora mostrando prótesis dental"
          loading="lazy" 
          class="w-full h-full object-contain object-bottom scale-110 origin-bottom transform translate-y-0"
        />
      </div>

    </div>

    <!-- Ondas suaves decorativas de fondo -->
    <div class="absolute right-0 bottom-0 w-48 h-48 rounded-full bg-[#cbdff2]/40 blur-lg z-0 pointer-events-none overflow-hidden"></div>

  </div>
</div>

</section>
